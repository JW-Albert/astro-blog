<button id="lang-toggle" aria-label="Toggle language / 切換語言">
	<span data-en>中文</span><span data-zh>EN</span>
</button>

<script>
	const html = document.documentElement;

	document.getElementById('lang-toggle')!.addEventListener('click', () => {
		const next = html.lang === 'zh-TW' ? 'en' : 'zh-TW';
		html.lang = next;
		localStorage.setItem('lang', next);
	});
</script>

<style>
	button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.3em 0.8em;
		font-size: 0.85em;
		font-family: inherit;
		font-weight: 700;
		color: var(--accent);
		background: transparent;
		border: 2px solid var(--accent);
		border-radius: 999px;
		cursor: pointer;
		line-height: 1;
		transition: background 0.15s, color 0.15s;
		white-space: nowrap;
	}
	button:hover {
		background: var(--accent);
		color: white;
	}
</style>
